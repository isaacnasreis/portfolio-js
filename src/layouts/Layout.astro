---
 // Just in case we need it, but we use public/assets
const { title = "Portfólio | Isaac N Reis - Desenvolvedor Full-Stack", description = "Portfólio de Isaac N Reis, desenvolvedor Full-Stack especializado na criação de aplicações web modernas e de alta qualidade, com foco em performance, responsividade e experiência do usuário." } = Astro.props;
---
<!doctype html>
<html lang="pt-br">
<head>
  <meta charset="UTF-8" />
  <meta name="author" content="Isaac N Reis" />
  <meta http-equiv="X-UA-Compatible" content="ie=edge" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <meta name="keywords" content="sites, web, desenvolvimento, programador, frontend, front-end, fullstack, full stack, freelancer, freela, website, portfólio" />
  <title>{title}</title>
  <link rel="shortcut icon" href="/portfolio-js/assets/img/logo.webp" type="image/x-icon" />
  <link rel="canonical" href="https://isaacnasreis.github.io/portfolio-js/" />
  <link rel="icon" href="/portfolio-js/assets/img/logo.webp" />
  <link rel="apple-touch-icon" href="/portfolio-js/assets/img/logo.webp" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Sora:wght@100;200;300;400;500;600;700;800&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/portfolio-js/assets/css/style.css" />
</head>
<body>
  <a href="#sobreMim" class="skip-link">Pular para conteúdo principal</a>
  <div class="scroll-progress-bar" id="scrollProgressBar" aria-hidden="true"></div>
  <slot />
  <script src="/portfolio-js/assets/js/skills-data.js" defer></script>
  <script src="/portfolio-js/assets/js/educations-data.js" defer></script>
  <script src="/portfolio-js/assets/js/projects-data.js" defer></script>
  <script src="/portfolio-js/assets/js/certificados-data.js" defer></script>
  <script src="/portfolio-js/assets/js/app.js" defer></script>

</body>
</html>
