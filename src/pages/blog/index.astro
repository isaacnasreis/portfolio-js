---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const posts = await getCollection('blog');
posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<Layout title="Blog | Isaac N Reis" description="Artigos sobre desenvolvimento Full-Stack, UX/UI, Performance e Carreira.">
  <Header />
  <main class="principal section">
    <section class="projetos__intro section" style="padding-top: 120px;">
      <div class="projetos__intro-text">
        <h1 class="projetos__titulo">Meu <span class="projetos__titulo-fw800">Blog</span></h1>
        <p class="projetos__subtitulo">Artigos, tutoriais e reflexões sobre desenvolvimento de software e design.</p>
      </div>
    </section>

    <section class="projetos__container section" style="display: grid; gap: 2rem; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));">
      {posts.map((post) => (
        <article class="projeto-card" style="padding: 2rem; border: 1px solid rgba(255, 255, 255, 0.1); border-radius: 12px; background: rgba(255, 255, 255, 0.02);">
          <div class="projeto-card__info" style="display: flex; flex-direction: column; gap: 1rem;">
            <p style="color: var(--secondary-text); font-size: 0.9rem;">
              {post.data.pubDate.toLocaleDateString('pt-BR', { year: 'numeric', month: 'long', day: 'numeric' })} &bull; ⏱️ {Math.max(1, Math.ceil((post.body || "").trim().split(/\s+/).length / 200))} min de leitura
            </p>
            <h2 style="font-size: 1.5rem; color: var(--primary-text);">{post.data.title}</h2>
            <p style="color: var(--secondary-text);">{post.data.description}</p>
            <div style="display: flex; gap: 0.5rem; flex-wrap: wrap; margin-top: auto;">
              {post.data.tags.map(tag => (
                <span style="font-size: 0.8rem; padding: 0.2rem 0.6rem; border-radius: 4px; background: rgba(255,255,255,0.1); color: var(--primary-text);">{tag}</span>
              ))}
            </div>
            <a href={`/portfolio/blog/${post.id}`} class="cta-button" style="margin-top: 1rem; text-align: center; display: inline-block; padding: 0.8rem;">Ler Artigo</a>
          </div>
        </article>
      ))}
    </section>
  </main>
  <Footer />
</Layout>
