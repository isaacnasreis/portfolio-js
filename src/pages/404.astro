---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="404 - Página não encontrada | Isaac N Reis" description="A página que você procura não existe ou foi movida.">
  <Header />
  <main class="principal section">
    <section class="not-found section" style="padding-top: 150px; padding-bottom: 150px; text-align: center; display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 60vh;">
      <h1 style="font-size: 8rem; font-weight: 800; color: var(--text-dark); line-height: 1; margin-bottom: 1rem;">404</h1>
      <h2 style="font-size: 2rem; color: var(--text-dark); margin-bottom: 1.5rem;">Oops! Página não encontrada.</h2>
      <p style="color: var(--text-muted-dark); font-size: 1.1rem; max-width: 500px; margin: 0 auto 3rem auto;">
        Parece que você se perdeu no espaço. A página que você está procurando pode ter sido removida, teve seu nome alterado ou está temporariamente indisponível.
      </p>
      <a href={import.meta.env.BASE_URL} class="cta-button" style="display: inline-flex; align-items: center; gap: 0.5rem; background: var(--bg-dark); color: var(--text-light); padding: 1rem 2rem; border-radius: 0.5rem; font-weight: 600; font-size: 1.1rem; transition: all 0.3s ease;">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M19 12H5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          <path d="M12 19L5 12L12 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        Voltar para o Início
      </a>
    </section>
  </main>
  <Footer />
</Layout>

<style>
  .cta-button:hover {
    transform: translateY(-3px);
    box-shadow: 0 10px 20px rgba(0,0,0,0.1);
  }
</style>
