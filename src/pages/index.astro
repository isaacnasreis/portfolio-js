---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---
<Layout>
  <Header />
  
  
  
  

  <main class="principal">
    <section class="banner section" aria-labelledby="banner-titulo">
      <img class="banner__imagem" src="/portfolio-js/assets/img/boy3.svg"
        alt="Ilustração em preto e branco de um menino sentado com um tablet na mão" />
      <div class="banner__textos">
        <div class="banner__titulo">
          <h1 id="banner-titulo">
            <div class="banner__titulo-row">
              <span class="banner__titulo-fw400">Olá eu sou&nbsp;</span>
              <span class="banner__titulo-fw800">Isaac N Reis.</span>
            </div>
            <div class="banner__titulo-row">
              <span class="banner__titulo-fw800">Full-Stack&nbsp;</span>
              <span class="banner__titulo-fw800 outlined">Developer</span>
            </div>
          </h1>
        </div>
        <div class="banner__descricao">
          Desenvolvedor Full-Stack e Web Designer focado na criação de experiências digitais completas. Minha atuação
          integra o planejamento estratégico, o design de interfaces (UX/UI) e o desenvolvimento técnico robusto, do
          front-end ao back-end. Transformo ideias complexas em aplicações responsivas, escaláveis e de alto desempenho,
          sempre priorizando a melhor jornada para o usuário final.
        </div>

        <ul class="banner__redes">
          <li>
            <a href="https://www.linkedin.com/in/isaacnreis/" target="_blank" rel="noopener noreferrer"
              class="banner__redes-link" aria-label="LinkedIn">
              <svg class="banner__redes-icon" width="20" height="20" viewBox="0 0 24 24"
                xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <path
                  d="M6.94 8.5A1.44 1.44 0 1 1 6.94 5.62A1.44 1.44 0 0 1 6.94 8.5ZM5.7 9.8h2.5V18h-2.5zM10.1 9.8h2.4v1.1h.03c.33-.63 1.16-1.3 2.4-1.3 2.57 0 3.07 1.69 3.07 3.88V18h-2.5v-3.97c0-.95-.02-2.16-1.32-2.16-1.32 0-1.52 1.03-1.52 2.09V18h-2.56V9.8z"
                  fill="currentColor" />
              </svg>
            </a>
          </li>
          <li role="listitem">
            <a href="https://github.com/isaacnasreis" target="_blank" rel="noopener noreferrer"
              class="banner__redes-link" aria-label="GitHub">
              <svg class="banner__redes-icon" width="20" height="20" viewBox="0 0 24 24"
                xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <path
                  d="M12 2a10 10 0 0 0-3.16 19.5c.5.09.68-.22.68-.48v-1.7c-2.77.6-3.35-1.18-3.35-1.18-.45-1.14-1.1-1.44-1.1-1.44-.9-.62.07-.6.07-.6 1 .07 1.52 1.02 1.52 1.02.88 1.52 2.31 1.08 2.88.83.09-.65.35-1.08.63-1.33-2.21-.25-4.54-1.1-4.54-4.9 0-1.08.39-1.96 1.02-2.65-.1-.25-.45-1.27.1-2.65 0 0 .84-.27 2.75 1.01a9.5 9.5 0 0 1 5 0c1.9-1.28 2.75-1 2.75-1 .54 1.38.2 2.4.1 2.65.63.69 1.01 1.57 1.01 2.65 0 3.8-2.34 4.64-4.57 4.88.36.31.68.92.68 1.86v2.76c0 .27.18.58.69.48A10 10 0 0 0 12 2z"
                  fill="currentColor" />
              </svg>
            </a>
          </li>
          <li role="listitem">
            <a href="https://x.com/IsaacNreis" target="_blank" rel="noopener noreferrer" class="banner__redes-link"
              aria-label="X">
              <svg class="banner__redes-icon" width="20" height="20" viewBox="0 0 24 24"
                xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <path
                  d="M18.9 3H21l-6.9 7.9L22 21h-6.2l-4.86-6.35L5.4 21H3.3l7.38-8.44L2 3h6.35l4.4 5.8L18.9 3zm-1.1 16h1.16L7.72 4.9H6.47z"
                  fill="currentColor" />
              </svg>
            </a>
          </li>

          <li role="listitem">
            <a href="https://www.youtube.com/@isaacnreisdev" target="_blank" rel="noopener noreferrer"
              class="banner__redes-link" aria-label="YouTube">
              <svg class="banner__redes-icon" width="20" height="20" viewBox="0 0 24 24"
                xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <path
                  d="M21.58 7.19a2.78 2.78 0 0 0-1.96-1.97C17.9 4.75 12 4.75 12 4.75s-5.9 0-7.62.47A2.78 2.78 0 0 0 2.42 7.2C1.96 8.92 1.96 12 1.96 12s0 3.08.46 4.8a2.78 2.78 0 0 0 1.96 1.97c1.72.47 7.62.47 7.62.47s5.9 0 7.62-.47a2.78 2.78 0 0 0 1.96-1.97c.46-1.72.46-4.8.46-4.8s0-3.08-.46-4.8zM9.9 15.03V8.97L15.1 12 9.9 15.03z"
                  fill="currentColor" />
              </svg>
            </a>
          </li>
          <li role="listitem">
            <a href="mailto:isaacreisn@gmail.com" class="banner__redes-link" aria-label="E-mail">
              <svg class="banner__redes-icon" width="20" height="20" viewBox="0 0 24 24"
                xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <path d="M3 6h18v12H3z" fill="none" stroke="currentColor" stroke-width="2" />
                <path d="M4 7l8 6 8-6" fill="none" stroke="currentColor" stroke-width="2" />
              </svg>
            </a>
          </li>
        </ul>
      </div>
    </section>

    <!-- Projetos logo após o hero para máximo impacto -->
    <section class="projetos" id="projetos" aria-labelledby="projetos-titulo">
      <div class="projetos__intro section">
        <div class="projetos__intro-text">
          <h2 class="projetos__titulo" id="projetos-titulo">
            Meus <span class="projetos__titulo-fw800">Projetos</span>
          </h2>
          <p class="projetos__subtitulo">Do design ao deploy — soluções completas que unem estratégia, interface e
            código.</p>
        </div>
        <div class="projetos__filtros" role="tablist" aria-label="Filtrar projetos por categoria">
          <button class="projetos__filtro active" data-filter="all" role="tab" aria-selected="true">Todos</button>
          <button class="projetos__filtro" data-filter="Full-Stack" role="tab" aria-selected="false">Full-Stack</button>
          <button class="projetos__filtro" data-filter="Frontend" role="tab" aria-selected="false">Frontend</button>
          <button class="projetos__filtro" data-filter="UI/UX" role="tab" aria-selected="false">UI/UX</button>
        </div>
      </div>
      <div class="projetos__container section"></div>
      <button class="projetos__toggle" type="button" aria-expanded="false">
        Ver mais projetos
      </button>
    </section>

    <section class="skills animate section" id="habilidades" aria-labelledby="habilidades-titulo">
      <h2 class="skills__titulo" id="habilidades-titulo">
        Minhas <span class="skills__titulo-fw800">Habilidades</span>
      </h2>
      <div class="skills__cards"></div>
    </section>

    <section class="sobreMim animate section" id="sobreMim" aria-labelledby="sobre-mim-titulo">
      <div class="sobreMim__imagem">
        <img src="/portfolio-js/assets/img/aboutme-boy.svg"
          alt="Ilustração em preto, branco e cinza de um menino com os braços cruzados com um sorriso confiante no rosto." />
      </div>
      <div class="sobreMim-container">
        <h2 class="sobreMim__titulo" id="sobre-mim-titulo">
          Sobre <span class="sobreMim__titulo-fw800">Mim</span>
        </h2>
        <p>
          Sou um profissional digital multifacetado, unindo a visão estética do Web Design com o rigor técnico do
          desenvolvimento Full-Stack. Minha jornada na tecnologia me proporcionou uma compreensão profunda de todo o
          ciclo de vida de um produto digital.
        </p>
        <p>
          No Front-end, crio interfaces dinâmicas, imersivas e acessíveis utilizando React, Vue.js e JavaScript moderno,
          garantindo uma performance impecável. No Back-end, construo arquiteturas seguras e escaláveis com Node.js,
          PHP, C# e integrações de banco de dados, sustentando a lógica de negócio de forma eficiente.
        </p>
        <p>
          Para elevar a qualidade das minhas entregas, estou cursando uma pós-graduação em UX Engineering. Essa
          especialização me permite transitar perfeitamente entre o Figma e o VS Code, garantindo que a usabilidade e a
          arquitetura da informação não se percam na tradução para o código.
        </p>
        <p>
          Fora do ambiente de desenvolvimento, busco inspiração na fotografia, na produção de animações e no estudo
          técnico do cinema, o que aguça meu olhar para detalhes visuais. Também mantenho o foco e a disciplina
          praticando esportes como basquete e corrida de rua.
        </p>
      </div>
    </section>

    <section class="formacoes" aria-labelledby="formacoes-titulo">
      <h2 class="formacoes__titulo" id="formacoes-titulo">
        Minhas <span class="formacoes__titulo-fw800">Formações</span>
      </h2>
      <div class="formacoes__container"></div>
      <div class="certificados__botao-container">
        <button class="certificados__botao ripple-btn" id="btn-certificados" aria-haspopup="dialog"
          aria-expanded="false">
          Ver Licenças e Certificados
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#f8f9fa" stroke-width="2"
            stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
            <path d="M9 12l2 2 4-4"></path>
          </svg>
        </button>
      </div>
    </section>

    <section class="contato animate section" id="contato" aria-labelledby="contato-titulo">
      <div class="form__container">
        <form action="https://formsubmit.co/ajax/isaacreisn@gmail.com" method="POST" data-form>
          <input type="hidden" name="_subject" value="Novo Contato do Portfólio!" />

          <input type="text" name="_honey" class="honeypot" />

          <input type="hidden" name="_time" />

          <label for="nome" class="sr-only">Seu nome</label>
          <input type="text" name="nome" id="nome" placeholder="Seu nome*" aria-describedby="error-nome" required />
          <span id="error-nome" class="error-message"></span>

          <label for="email" class="sr-only">Seu email</label>
          <input type="email" name="email" id="email" placeholder="Email*" aria-describedby="error-email" required />
          <span id="error-email" class="error-message"></span>

          <label for="site" class="sr-only">Seu site</label>
          <input type="text" name="site" id="site" placeholder="Seu site (Se existir)" />

          <label for="mensagem" class="sr-only">Sua mensagem</label>
          <textarea name="mensagem" id="mensagem" placeholder="Como posso te ajudar*" aria-describedby="error-mensagem"
            required></textarea>
          <span id="error-mensagem" class="error-message"></span>
          <span class="form__campos-obrigatorios">*Campos obrigatórios</span>
          <div class="form__submitButton-container">
            <button class="form__submitButton" type="submit" data-button>
              Enviar
            </button>
            <ul class="banner__redes form__submitButton__redes">
              <li role="listitem">
                <a href="https://www.linkedin.com/in/isaacnreis/" target="_blank" rel="noopener noreferrer"
                  class="banner__redes-link" aria-label="LinkedIn">
                  <svg class="banner__redes-icon" width="20" height="20" viewBox="0 0 24 24"
                    xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                    <path
                      d="M6.94 8.5A1.44 1.44 0 1 1 6.94 5.62A1.44 1.44 0 0 1 6.94 8.5ZM5.7 9.8h2.5V18h-2.5zM10.1 9.8h2.4v1.1h.03c.33-.63 1.16-1.3 2.4-1.3 2.57 0 3.07 1.69 3.07 3.88V18h-2.5v-3.97c0-.95-.02-2.16-1.32-2.16-1.32 0-1.52 1.03-1.52 2.09V18h-2.56V9.8z"
                      fill="currentColor" />
                  </svg>
                </a>
              </li>
              <li role="listitem">
                <a href="https://github.com/isaacnasreis" target="_blank" rel="noopener noreferrer"
                  class="banner__redes-link" aria-label="GitHub">
                  <svg class="banner__redes-icon" width="20" height="20" viewBox="0 0 24 24"
                    xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                    <path
                      d="M12 2a10 10 0 0 0-3.16 19.5c.5.09.68-.22.68-.48v-1.7c-2.77.6-3.35-1.18-3.35-1.18-.45-1.14-1.1-1.44-1.1-1.44-.9-.62.07-.6.07-.6 1 .07 1.52 1.02 1.52 1.02.88 1.52 2.31 1.08 2.88.83.09-.65.35-1.08.63-1.33-2.21-.25-4.54-1.1-4.54-4.9 0-1.08.39-1.96 1.02-2.65-.1-.25-.45-1.27.1-2.65 0 0 .84-.27 2.75 1.01a9.5 9.5 0 0 1 5 0c1.9-1.28 2.75-1 2.75-1 .54 1.38.2 2.4.1 2.65.63.69 1.01 1.57 1.01 2.65 0 3.8-2.34 4.64-4.57 4.88.36.31.68.92.68 1.86v2.76c0 .27.18.58.69.48A10 10 0 0 0 12 2z"
                      fill="currentColor" />
                  </svg>
                </a>
              </li>
              <li role="listitem">
                <a href="https://x.com/IsaacNreis" target="_blank" rel="noopener noreferrer" class="banner__redes-link"
                  aria-label="X">
                  <svg class="banner__redes-icon" width="20" height="20" viewBox="0 0 24 24"
                    xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                    <path
                      d="M18.9 3H21l-6.9 7.9L22 21h-6.2l-4.86-6.35L5.4 21H3.3l7.38-8.44L2 3h6.35l4.4 5.8L18.9 3zm-1.1 16h1.16L7.72 4.9H6.47z"
                      fill="currentColor" />
                  </svg>
                </a>
              </li>

              <li role="listitem">
                <a href="https://www.youtube.com/@isaacnreisdev" target="_blank" rel="noopener noreferrer"
                  class="banner__redes-link" aria-label="YouTube">
                  <svg class="banner__redes-icon" width="20" height="20" viewBox="0 0 24 24"
                    xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                    <path
                      d="M21.58 7.19a2.78 2.78 0 0 0-1.96-1.97C17.9 4.75 12 4.75 12 4.75s-5.9 0-7.62.47A2.78 2.78 0 0 0 2.42 7.2C1.96 8.92 1.96 12 1.96 12s0 3.08.46 4.8a2.78 2.78 0 0 0 1.96 1.97c1.72.47 7.62.47 7.62.47s5.9 0 7.62-.47a2.78 2.78 0 0 0 1.96-1.97c.46-1.72.46-4.8.46-4.8s0-3.08-.46-4.8zM9.9 15.03V8.97L15.1 12 9.9 15.03z"
                      fill="currentColor" />
                  </svg>
                </a>
              </li>
              <li role="listitem">
                <a href="mailto:isaacreisn@gmail.com" class="banner__redes-link" aria-label="E-mail">
                  <svg class="banner__redes-icon" width="20" height="20" viewBox="0 0 24 24"
                    xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                    <path d="M3 6h18v12H3z" fill="none" stroke="currentColor" stroke-width="2" />
                    <path d="M4 7l8 6 8-6" fill="none" stroke="currentColor" stroke-width="2" />
                  </svg>
                </a>
              </li>
            </ul>
          </div>
        </form>
      </div>
      <div class="contato__info">
        <div class="contato__info-titulos">
          <h2 class="contato__info__titulo" id="contato-titulo">
            Vamos <span class="outlined">conversar</span> sobre
          </h2>
          <h2 class="contato__info__titulo">Algumas coisas especiais</h2>
        </div>
        <div class="contato__info-descricao">
          <p>
            Meu objetivo é ir além do código para criar experiências digitais
            intuitivas, envolventes e memoráveis, que realmente se conectem
            com o usuário.
          </p>
        </div>
        <div class="contato__info-meios">
          <h3>isaacreisn@gmail.com</h3>
          <h3>+55 (31) 99225-7835</h3>
        </div>
      </div>
    </section>

    <section id="cta" class="cta-section animate section" aria-labelledby="cta-titulo">
      <div class="container">
        <h2 id="cta-titulo">Vamos Tirar Sua Ideia do Papel?</h2>
        <p>
          Se você busca um desenvolvedor comprometido para construir uma
          aplicação web moderna, um site institucional ou uma landing page de
          alta conversão, adoraria conversar. Entre em contato e vamos
          transformar seu projeto em realidade.
        </p>
        <div class="cta-contacts">
          <a href="https://github.com/isaacnasreis" target="_blank" rel="noopener noreferrer" class="cta-button github">
            <svg class="banner__redes-icon" width="20" height="20" viewBox="0 0 24 24"
              xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <path
                d="M12 2a10 10 0 0 0-3.16 19.5c.5.09.68-.22.68-.48v-1.7c-2.77.6-3.35-1.18-3.35-1.18-.45-1.14-1.1-1.44-1.1-1.44-.9-.62.07-.6.07-.6 1 .07 1.52 1.02 1.52 1.02.88 1.52 2.31 1.08 2.88.83.09-.65.35-1.08.63-1.33-2.21-.25-4.54-1.1-4.54-4.9 0-1.08.39-1.96 1.02-2.65-.1-.25-.45-1.27.1-2.65 0 0 .84-.27 2.75 1.01a9.5 9.5 0 0 1 5 0c1.9-1.28 2.75-1 2.75-1 .54 1.38.2 2.4.1 2.65.63.69 1.01 1.57 1.01 2.65 0 3.8-2.34 4.64-4.57 4.88.36.31.68.92.68 1.86v2.76c0 .27.18.58.69.48A10 10 0 0 0 12 2z"
                fill="currentColor" />
            </svg>
            GitHub
          </a>
          <a href="https://www.linkedin.com/in/isaacnreis/" target="_blank" rel="noopener noreferrer"
            class="cta-button linkedin">
            <svg class="banner__redes-icon" width="20" height="20" viewBox="0 0 24 24"
              xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <path
                d="M6.94 8.5A1.44 1.44 0 1 1 6.94 5.62A1.44 1.44 0 0 1 6.94 8.5ZM5.7 9.8h2.5V18h-2.5zM10.1 9.8h2.4v1.1h.03c.33-.63 1.16-1.3 2.4-1.3 2.57 0 3.07 1.69 3.07 3.88V18h-2.5v-3.97c0-.95-.02-2.16-1.32-2.16-1.32 0-1.52 1.03-1.52 2.09V18h-2.56V9.8z"
                fill="currentColor" />
            </svg>
            LinkedIn
          </a>
          <a href="mailto:isaacreisn@gmail.com" target="_blank" rel="noopener noreferrer" class="cta-button email">
            <svg class="banner__redes-icon" width="20" height="20" viewBox="0 0 24 24"
              xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <path
                d="M20 4H4a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V6a2 2 0 0 0-2-2zm0 4-8 5-8-5V6l8 5 8-5v2z"
                fill="currentColor" />
            </svg>
            E-mail
          </a>
        </div>
      </div>
    </section>

    <!-- Modal de Projeto -->
    <div class="projeto-modal" id="projetoModal" aria-hidden="true">
      <div class="projeto-modal__backdrop" data-close-modal></div>
      <div class="projeto-modal__content" role="dialog" aria-modal="true" aria-labelledby="modal-titulo">
        <button class="projeto-modal__fechar" data-close-modal aria-label="Fechar modal">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
            stroke-linecap="round" stroke-linejoin="round">
            <line x1="18" y1="6" x2="6" y2="18"></line>
            <line x1="6" y1="6" x2="18" y2="18"></line>
          </svg>
        </button>
        <div class="projeto-modal__header">
          <h2 id="modal-titulo" class="projeto-modal__titulo">Título do Projeto</h2>
        </div>
        <div class="projeto-modal__body">
          <div class="projeto-modal__galeria" id="modalGaleria">
            <!-- Imagens serão injetadas aqui -->
          </div>
          <div class="projeto-modal__info">
            <div class="projeto-modal__tags" id="modalTags">
              <!-- Tags serão injetadas aqui -->
            </div>
            <p class="projeto-modal__descricao" id="modalDescricao">
              Descrição completa do projeto.
            </p>
            <div class="projeto-modal__links" id="modalLinks">
              <!-- Links (Demo, Repo, Figma) serão injetados aqui -->
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Modal de Certificados -->
    <div class="certificado-modal" id="certificadoModal" aria-hidden="true">
      <div class="certificado-modal__backdrop" data-close-certificado-modal></div>
      <div class="certificado-modal__content" role="dialog" aria-modal="true"
        aria-labelledby="certificado-modal-titulo">
        <button class="certificado-modal__fechar" data-close-certificado-modal aria-label="Fechar modal">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
            stroke-linecap="round" stroke-linejoin="round">
            <line x1="18" y1="6" x2="6" y2="18"></line>
            <line x1="6" y1="6" x2="18" y2="18"></line>
          </svg>
        </button>
        <div class="certificado-modal__header">
          <h2 id="certificado-modal-titulo" class="certificado-modal__titulo">Licenças e Certificados</h2>
        </div>
        <div class="certificado-modal__body">
          <div class="certificados-lista" id="certificadosLista">
            <!-- Certificados injectados via JS -->
          </div>
        </div>
      </div>
    </div>
  </main>

  

  
  <Footer />
</Layout>
